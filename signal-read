#!/bin/bash
# Read messages from the Signal bridge log
# Filters by project prefix derived from cwd (strips leading "claude-")
set -euo pipefail

CONFIG="$HOME/.config/signal-bridge/config"
[ -f "$CONFIG" ] || { echo "Config not found: $CONFIG"; exit 1; }
source "$CONFIG"

LOG="${LOG_FILE:-$HOME/.local/share/signal-bridge/messages.log}"
PROJECT="${SIGNAL_PROJECT:-$(basename "$PWD" | sed 's/^claude-//')}"

usage() {
    echo "Usage: signal-read [--wait] [--last N] [--clear] [--all]"
    echo "  (no args)   Show last 10 messages for this project ($PROJECT)"
    echo "  --wait      Block until a message for this project arrives"
    echo "  --last N    Show last N messages for this project (default: 10)"
    echo "  --all       Show all messages, ignore project filter"
    echo "  --clear     Clear the message log"
    exit 0
}

# Filter: only messages starting with "project:" (case-insensitive)
filter_project() {
    jq -r --arg pfx "$PROJECT" 'select(.message | test("^" + $pfx + ":")) | "\(.timestamp) [\(.sender)] \(.message)"' 2>/dev/null
}

case "${1:-}" in
    --wait)
        [ ! -f "$LOG" ] && touch "$LOG"
        tail -n0 -f "$LOG" | while IFS= read -r line; do
            MATCH=$(echo "$line" | jq -r --arg pfx "$PROJECT" 'select(.message | test("^" + $pfx + ":")) | "\(.timestamp) [\(.sender)] \(.message)"' 2>/dev/null)
            if [ -n "$MATCH" ]; then
                echo "$MATCH"
                break
            fi
        done
        ;;
    --last)
        N="${2:-10}"
        [ ! -f "$LOG" ] && { echo "No messages yet."; exit 0; }
        grep "\"message\":.*\"${PROJECT}:" "$LOG" | tail -n "$N" | jq -r '"\(.timestamp) [\(.sender)] \(.message)"' 2>/dev/null
        ;;
    --all)
        [ ! -f "$LOG" ] && { echo "No messages yet."; exit 0; }
        tail -n 10 "$LOG" | jq -r '"\(.timestamp) [\(.sender)] \(.message)"' 2>/dev/null
        ;;
    --clear)
        > "$LOG"
        echo "Log cleared."
        ;;
    --help|-h)
        usage
        ;;
    *)
        [ ! -f "$LOG" ] && { echo "No messages yet."; exit 0; }
        grep "\"message\":.*\"${PROJECT}:" "$LOG" | tail -n 10 | jq -r '"\(.timestamp) [\(.sender)] \(.message)"' 2>/dev/null
        ;;
esac
